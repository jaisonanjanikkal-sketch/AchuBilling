{
  "name": "anjanikkal-root",
  "version": "1.0.0",
  "description": "Root runner for Anjanikkal Smart Billing",
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
